#!/usr/bin/env bash
# proxy-multi - turn a list of proxies into an Xray (x-ui) load-balancer.
#
# Interactively asks how many proxies you have, reads "host:port:user:pass" lines,
# tests each one (auto-detects http/socks5, finds the real exit IP + geo, drops the
# dead ones), then generates a ready Xray outbounds + balancer config for x-ui/Xray.
#
# Dependencies: curl only.
# License: MIT
set -euo pipefail

VERSION="0.3.0"

STATE_DIR="${STATE_DIR:-/etc/proxy-multi}"
OUT_JSON="${OUT_JSON:-${STATE_DIR}/xray-outbounds.json}"
PROXY_LIST="${PROXY_LIST:-${STATE_DIR}/proxies.list}"
PROXY_ROTATE_FILE="${PROXY_ROTATE_FILE:-${STATE_DIR}/rotate.min}"

GEO_URL="${GEO_URL:-https://ipinfo.io/json}"
TRACE_URL="${TRACE_URL:-https://cloudflare.com/cdn-cgi/trace}"
TEST_TIMEOUT="${TEST_TIMEOUT:-15}"

BALANCER_TAG="${BALANCER_TAG:-proxy-balancer}"
TAG_PREFIX="${TAG_PREFIX:-px}"
BALANCER_STRATEGY="${BALANCER_STRATEGY:-random}"   # used only by the generated OUT_JSON; apply uses leastPing
# Health-check probe for automatic failover (returns HTTP 204). Detection ~ interval*sampling.
# Timeout is generous because WARP-through-a-distant-proxy adds latency (avoid false "dead").
PROBE_URL="${PROBE_URL:-https://cp.cloudflare.com/generate_204}"
PROBE_INTERVAL="${PROBE_INTERVAL:-20s}"
PROBE_TIMEOUT="${PROBE_TIMEOUT:-12s}"
PROBE_SAMPLING="${PROBE_SAMPLING:-2}"

# x-ui (3x-ui / MHSanaei) integration
XUI_DB="${XUI_DB:-/etc/x-ui/x-ui.db}"
XUI_SERVICE="${XUI_SERVICE:-x-ui}"
XRAY_KEY="${XRAY_KEY:-xrayTemplateConfig}"
# When xrayTemplateConfig isn't in the DB yet (panel never customized), derive the base
# template from the running Xray config (keep only the internal "api" inbound).
XUI_RUNNING_CONFIG="${XUI_RUNNING_CONFIG:-/usr/local/x-ui/bin/config.json}"

log()  { echo "[$(date +'%F %T')] $*"; }
warn() { echo "WARN: $*" >&2; }
die()  { echo "ERROR: $*" >&2; exit 1; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }

ensure_tools() {
  has_cmd curl || die "curl is required (apt-get install -y curl)."
}

# Minimal JSON string escaper (handles backslash and double-quote).
json_escape() {
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# Extract a top-level string field from a (pretty-printed) JSON blob without jq.
get_json_field() {
  local json="$1" field="$2"
  printf '%s' "$json" | grep -oE "\"${field}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | head -1 \
    | sed -E "s/.*:[[:space:]]*\"([^\"]*)\"/\1/"
}

# Parse one proxy line into P_HOST/P_PORT/P_USER/P_PASS/P_SCHEME.
# Accepts:  host:port:user:pass   |   host:port   |   scheme://[user:pass@]host:port
parse_proxy() {
  local line="${1:-}"
  line="${line//[[:space:]]/}"
  P_HOST=""; P_PORT=""; P_USER=""; P_PASS=""; P_SCHEME=""
  [[ -n "$line" ]] || return 1

  if [[ "$line" == *"://"* ]]; then
    P_SCHEME="${line%%://*}"
    line="${line#*://}"
    if [[ "$line" == *"@"* ]]; then
      local creds="${line%@*}" hostport="${line##*@}"
      P_USER="${creds%%:*}"; P_PASS="${creds#*:}"
      P_HOST="${hostport%%:*}"; P_PORT="${hostport##*:}"
    else
      P_HOST="${line%%:*}"; P_PORT="${line##*:}"
    fi
  else
    local -a f=()
    IFS=':' read -r -a f <<<"$line"
    case "${#f[@]}" in
      2) P_HOST="${f[0]}"; P_PORT="${f[1]}" ;;
      4) P_HOST="${f[0]}"; P_PORT="${f[1]}"; P_USER="${f[2]}"; P_PASS="${f[3]}" ;;
      *) return 1 ;;
    esac
  fi

  [[ -n "$P_HOST" && "$P_PORT" =~ ^[0-9]+$ ]] || return 1
  return 0
}

# Test a proxy. On success sets T_PROTO (http|socks), T_IP, T_GEO, T_ORG and returns 0.
# Auto-detects the protocol unless P_SCHEME forces one.
test_proxy() {
  local host="$1" port="$2" user="$3" pass="$4" want="${5:-}"
  local auth="" s url out ip
  [[ -n "$user" ]] && auth="${user}:${pass}@"

  local -a schemes
  case "$want" in
    http)                 schemes=(http) ;;
    socks|socks5|socks5h) schemes=(socks5h) ;;
    *)                    schemes=(http socks5h) ;;
  esac

  T_PROTO=""; T_IP=""; T_GEO=""; T_ORG=""
  for s in "${schemes[@]}"; do
    url="${s}://${auth}${host}:${port}"
    out="$(curl -s --max-time "$TEST_TIMEOUT" --proxy "$url" "$GEO_URL" 2>/dev/null || true)"
    ip="$(get_json_field "$out" ip)"
    if [[ -z "$ip" ]]; then
      # Fallback: cloudflare trace (gives ip only, no geo).
      out="$(curl -s --max-time "$TEST_TIMEOUT" --proxy "$url" "$TRACE_URL" 2>/dev/null || true)"
      ip="$(printf '%s' "$out" | sed -n 's/^ip=//p' | head -1)"
      if [[ -n "$ip" ]]; then
        T_PROTO="$([[ "$s" == "http" ]] && echo http || echo socks)"
        T_IP="$ip"
        T_GEO="$(printf '%s' "$out" | sed -n 's/^loc=//p' | head -1)"
        T_ORG=""
        return 0
      fi
      continue
    fi
    T_PROTO="$([[ "$s" == "http" ]] && echo http || echo socks)"
    T_IP="$ip"
    local city region country
    city="$(get_json_field "$out" city)"
    region="$(get_json_field "$out" region)"
    country="$(get_json_field "$out" country)"
    T_GEO="$(printf '%s' "${city:+$city, }${region:+$region, }${country}" | sed 's/, *$//')"
    T_ORG="$(get_json_field "$out" org)"
    return 0
  done
  return 1
}

# Emit one Xray outbound object (indented) for a working proxy.
gen_outbound() {
  local tag="$1" proto="$2" host="$3" port="$4" user="$5" pass="$6"
  local users=""
  if [[ -n "$user" ]]; then
    users=", \"users\": [{ \"user\": \"$(json_escape "$user")\", \"pass\": \"$(json_escape "$pass")\" }]"
  fi
  printf '    { "tag": "%s", "protocol": "%s", "settings": { "servers": [{ "address": "%s", "port": %s%s }] } }' \
    "$(json_escape "$tag")" "$proto" "$(json_escape "$host")" "$port" "$users"
}

read_proxy_lines() {
  # Populates the global INPUT_LINES array, either from --file or interactively.
  INPUT_LINES=()
  if [[ -n "${PROXY_FILE:-}" ]]; then
    [[ -f "$PROXY_FILE" ]] || die "File not found: $PROXY_FILE"
    mapfile -t INPUT_LINES < "$PROXY_FILE"
    return 0
  fi

  local n
  read -rp "How many proxies do you want to add? " n
  [[ "$n" =~ ^[0-9]+$ ]] && [[ "$n" -ge 1 ]] || die "Enter a number >= 1."
  echo "Paste each proxy on its own line (host:port:user:pass)."
  local i line
  for i in $(seq 1 "$n"); do
    read -rp "  proxy $i: " line
    INPUT_LINES+=("$line")
  done
}

# Test every line in INPUT_LINES, persist the valid ones to PROXY_LIST, generate
# OUT_JSON from the working proxies, then auto-apply to x-ui.
process_proxies() {
  local -a outbounds=() tags=() saved=()
  local idx=0 line tag
  printf '\n%-24s %-6s %-16s %-26s %s\n' "PROXY" "PROTO" "EXIT_IP" "GEO" "STATUS"
  printf '%s\n' "--------------------------------------------------------------------------------"
  for line in "${INPUT_LINES[@]}"; do
    [[ -n "${line//[[:space:]]/}" ]] || continue
    if ! parse_proxy "$line"; then
      printf '%-24s %-6s %-16s %-26s %s\n' "$line" "-" "-" "-" "BAD-FORMAT"
      continue
    fi
    saved+=("$line")
    idx=$((idx + 1))
    tag="${TAG_PREFIX}$(printf '%02d' "$idx")"
    if [[ "${NO_TEST:-0}" -eq 1 ]]; then
      # Wire without testing — let the x-ui health-check (observatory) decide liveness at runtime.
      local proto2; proto2="$([[ "$P_SCHEME" == http* ]] && echo http || echo socks)"
      printf '%-24s %-6s %-16s %-26s %s\n' "${P_HOST}:${P_PORT}" "$proto2" "-" "(untested)" "WIRED ($tag)"
      outbounds+=("$(gen_outbound "$tag" "$proto2" "$P_HOST" "$P_PORT" "$P_USER" "$P_PASS")")
      tags+=("$tag")
    elif test_proxy "$P_HOST" "$P_PORT" "$P_USER" "$P_PASS" "$P_SCHEME"; then
      printf '%-24s %-6s %-16s %-26s %s\n' "${P_HOST}:${P_PORT}" "$T_PROTO" "$T_IP" "${T_GEO:-?}" "OK ($tag)"
      outbounds+=("$(gen_outbound "$tag" "$T_PROTO" "$P_HOST" "$P_PORT" "$P_USER" "$P_PASS")")
      tags+=("$tag")
    else
      printf '%-24s %-6s %-16s %-26s %s\n' "${P_HOST}:${P_PORT}" "-" "-" "-" "DEAD/skip"
    fi
  done
  echo

  # Persist the valid (parseable) lines so `add` can extend the list later.
  if [[ "${#saved[@]}" -ge 1 ]]; then printf '%s\n' "${saved[@]}" > "$PROXY_LIST"; fi

  [[ "${#tags[@]}" -ge 1 ]] || die "No working proxy found; nothing to generate."

  local obs_joined="" o first=1
  for o in "${outbounds[@]}"; do
    if [[ "$first" -eq 1 ]]; then obs_joined="$o"; first=0; else obs_joined="${obs_joined},"$'\n'"$o"; fi
  done
  local tags_joined="" t
  for t in "${tags[@]}"; do tags_joined="${tags_joined:+$tags_joined, }\"$(json_escape "$t")\""; done

  cat > "$OUT_JSON" <<EOF
{
  "outbounds": [
${obs_joined}
  ],
  "routing": {
    "balancers": [
      { "tag": "${BALANCER_TAG}", "selector": [${tags_joined}], "strategy": { "type": "${BALANCER_STRATEGY}" } }
    ],
    "rules": [
      { "type": "field", "inboundTag": ["YOUR_INBOUND_TAG"], "balancerTag": "${BALANCER_TAG}" }
    ]
  }
}
EOF

  log "Generated config for ${#tags[@]} working proxy(ies): $OUT_JSON  (saved ${#saved[@]} in $PROXY_LIST)"
  echo "-------------------- Xray config --------------------"
  cat "$OUT_JSON"
  echo "-----------------------------------------------------"
  echo

  if [[ "${NO_APPLY:-0}" -ne 1 ]] && [[ -f "$XUI_DB" ]]; then
    log "x-ui detected ($XUI_DB) -> applying automatically..."
    cmd_apply
  else
    echo "x-ui not detected (or --no-apply). Apply manually:"
    echo "  Panel -> Xray Configs -> merge the 'outbounds' and 'routing' above,"
    echo "  replace YOUR_INBOUND_TAG with your inbound tag, Save, Restart."
  fi
}

cmd_setup() {
  ensure_tools
  mkdir -p "$STATE_DIR"
  local -a INPUT_LINES=()
  read_proxy_lines
  process_proxies
}

# Append more proxies to the saved list without re-entering the old ones.
cmd_add() {
  ensure_tools
  mkdir -p "$STATE_DIR"
  local -a INPUT_LINES=()
  [[ -f "$PROXY_LIST" ]] && mapfile -t INPUT_LINES < "$PROXY_LIST"
  local had="${#INPUT_LINES[@]}"
  log "Saved proxies so far: ${had}. New ones get appended (existing keep their px tags)."

  if [[ -n "${PROXY_FILE:-}" ]]; then
    local l
    while IFS= read -r l; do [[ -n "${l//[[:space:]]/}" ]] && INPUT_LINES+=("$l"); done < "$PROXY_FILE"
  else
    local n
    read -rp "How many MORE proxies to add? " n
    [[ "$n" =~ ^[0-9]+$ ]] && [[ "$n" -ge 1 ]] || die "Enter a number >= 1."
    echo "Paste each NEW proxy on its own line (host:port:user:pass)."
    local i line
    for i in $(seq 1 "$n"); do
      read -rp "  new proxy $i: " line
      [[ -n "${line//[[:space:]]/}" ]] && INPUT_LINES+=("$line")
    done
  fi

  [[ "${#INPUT_LINES[@]}" -gt "$had" ]] || die "No new proxies were added."
  process_proxies
}

# --- x-ui (3x-ui) auto-apply -------------------------------------------------

ensure_apply_tools() {
  has_cmd sqlite3 || { log "Installing sqlite3..."; apt-get install -y -q sqlite3 >/dev/null 2>&1 || true; }
  has_cmd jq      || { log "Installing jq...";      apt-get install -y -q jq      >/dev/null 2>&1 || true; }
  has_cmd sqlite3 || die "sqlite3 is required (apt-get install -y sqlite3)."
  has_cmd jq      || die "jq is required (apt-get install -y jq)."
}

# JSON array of enabled inbound tags from the x-ui DB.
xui_inbound_tags() {
  sqlite3 "$XUI_DB" "SELECT tag FROM inbounds WHERE enable=1 AND tag IS NOT NULL AND tag<>'';" 2>/dev/null \
    | jq -R . | jq -s 'map(select(length>0))'
}

cmd_apply() {
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "Run as root to modify x-ui."
  ensure_apply_tools
  [[ -f "$OUT_JSON" ]] || die "No generated config ($OUT_JSON). Run: proxy-multi setup"
  [[ -f "$XUI_DB" ]]   || die "x-ui DB not found at $XUI_DB (set XUI_DB=/path/to/x-ui.db)."

  # Current Xray template from the panel DB; if it doesn't exist yet (panel never had its
  # Xray config customized), derive the base from the running config — keep only the
  # internal "api" inbound, since the panel re-injects the user inbounds from the DB.
  local tmpl tmpl_missing=0
  tmpl="$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='${XRAY_KEY}';" 2>/dev/null || true)"
  if [[ -z "$tmpl" ]]; then
    [[ -f "$XUI_RUNNING_CONFIG" ]] || die "No '${XRAY_KEY}' in DB and no running config at $XUI_RUNNING_CONFIG. Open Panel -> Xray Configs -> Save once, then re-run."
    tmpl="$(jq '.inbounds = [((.inbounds // [])[]) | select(.tag == "api")]' "$XUI_RUNNING_CONFIG" 2>/dev/null || true)"
    printf '%s' "$tmpl" | jq empty 2>/dev/null || die "Could not derive a base template from $XUI_RUNNING_CONFIG."
    tmpl_missing=1
    log "No saved Xray template in DB; derived base from running config (will create it)."
  fi
  printf '%s' "$tmpl" | jq empty 2>/dev/null || die "Existing template is not valid JSON; aborting (DB untouched)."

  # Which inbound tags route through the proxies.
  local intags
  if [[ -n "${APPLY_INBOUND:-}" && "$APPLY_INBOUND" != "all" ]]; then
    intags="$(printf '%s' "$APPLY_INBOUND" | tr ',' '\n' | jq -R . | jq -s 'map(select(length>0))')"
  else
    intags="$(xui_inbound_tags)"
  fi
  [[ "$(printf '%s' "$intags" | jq 'length')" -ge 1 ]] \
    || die "No enabled inbounds found to route. Create an inbound first, or pass --inbound <tag>."

  # Backup the DB before touching it.
  local stamp bak
  stamp="$(date +%Y%m%d-%H%M%S)"
  bak="${XUI_DB}.proxymulti.${stamp}.bak"
  cp -f "$XUI_DB" "$bak" || die "DB backup failed; aborting."
  log "DB backed up: $bak"

  # Routing mode:
  #   rotate mode (--rotate N)  -> all traffic to ONE proxy, a timer cycles it. NOTE: each
  #                                cycle restarts x-ui, which briefly drops every connection
  #                                through it (e.g. a rathole tunnel). Opt-in only.
  #   failover mode (default)   -> leastPing balancer + health-checked burstObservatory:
  #                                routes to a healthy proxy, automatically fails over off a
  #                                dead one, with NO x-ui restarts (no disruption to other tunnels).
  local ourbal ourrule obs firstpx0
  firstpx0="$(jq -r '.outbounds[0].tag' "$OUT_JSON" 2>/dev/null || true)"
  [[ -n "$firstpx0" ]] || firstpx0="${TAG_PREFIX}01"
  if [[ "${ROTATE_MINUTES:-0}" -gt 0 ]]; then
    ourbal='[]'
    ourrule="$(jq -nc --argjson intags "$intags" --arg ob "$firstpx0" '{type:"field", inboundTag:$intags, outboundTag:$ob}')"
    obs='null'
  else
    ourbal="$(jq -nc --arg bt "$BALANCER_TAG" --arg pfx "$TAG_PREFIX" --arg fb "$firstpx0" '[{tag:$bt, selector:[$pfx], fallbackTag:$fb, strategy:{type:"leastPing"}}]')"
    ourrule="$(jq -nc --argjson intags "$intags" --arg bt "$BALANCER_TAG" '{type:"field", inboundTag:$intags, balancerTag:$bt}')"
    obs="$(jq -nc --arg pfx "$TAG_PREFIX" --arg url "$PROBE_URL" --arg iv "$PROBE_INTERVAL" --arg to "$PROBE_TIMEOUT" --argjson sp "$PROBE_SAMPLING" \
      '{subjectSelector:[$pfx], pingConfig:{destination:$url, interval:$iv, sampling:$sp, timeout:$to, httpMethod:"HEAD"}}')"
  fi

  # Merge into the template (idempotent; cleans up the other mode; preserves existing config).
  local merged
  merged="$(printf '%s' "$tmpl" | jq \
    --slurpfile px "$OUT_JSON" \
    --argjson ourbal "$ourbal" \
    --argjson ourrule "$ourrule" \
    --argjson obs "$obs" \
    --arg baltag "$BALANCER_TAG" \
    --arg pfx "$TAG_PREFIX" '
    ($px[0].outbounds) as $pxob
    | .outbounds = ((.outbounds // []) | map(select(((.tag // "") | test("^"+$pfx+"[0-9]+$")) | not))) + $pxob
    | .routing = (.routing // {})
    | .routing.balancers = ((.routing.balancers // []) | map(select(.tag != $baltag))) + $ourbal
    | .routing.rules = ((.routing.rules // []) | map(select(
          ((.balancerTag // "") != $baltag)
          and (((.outboundTag // "") | test("^"+$pfx+"[0-9]+$")) | not)
      ))) + [$ourrule]
    | (if $obs == null
         then (if ((.burstObservatory.subjectSelector // []) == [$pfx]) then del(.burstObservatory) else . end)
         else .burstObservatory = $obs end)
  ' 2>/dev/null)" || { warn "merge failed"; die "jq merge failed; DB untouched (backup: $bak)."; }
  printf '%s' "$merged" | jq empty 2>/dev/null || die "Merged config invalid; DB untouched (backup: $bak)."

  # Write the merged template back: INSERT a new row if it didn't exist, else UPDATE.
  printf '%s' "$merged" > "${STATE_DIR}/merged-template.json"
  local ok=1
  if [[ "$tmpl_missing" -eq 1 ]]; then
    { printf "INSERT INTO settings (key,value) VALUES ('%s','" "$XRAY_KEY"; sed "s/'/''/g" "${STATE_DIR}/merged-template.json"; printf "');"; } | sqlite3 "$XUI_DB" || ok=0
  else
    { printf "UPDATE settings SET value='"; sed "s/'/''/g" "${STATE_DIR}/merged-template.json"; printf "' WHERE key='%s';" "$XRAY_KEY"; } | sqlite3 "$XUI_DB" || ok=0
  fi
  if [[ "$ok" -ne 1 ]]; then
    cp -f "$bak" "$XUI_DB"
    die "DB write failed; restored backup ($bak)."
  fi
  local nprox routed
  nprox="$(jq '.outbounds | length' "$OUT_JSON" 2>/dev/null || echo '?')"
  routed="$(printf '%s' "$intags" | jq -cr 'join(", ")' 2>/dev/null || echo '?')"
  if [[ "${ROTATE_MINUTES:-0}" -gt 0 ]]; then
    log "x-ui template updated (${nprox} proxies; ALL of [${routed}] -> one active proxy, rotating every ${ROTATE_MINUTES}m via restart)."
  else
    log "x-ui template updated (${nprox} proxies; [${routed}] -> ${BALANCER_TAG} leastPing + health-check failover, no restarts)."
  fi

  # Restart and verify; auto-rollback if the panel fails to come up.
  systemctl restart "$XUI_SERVICE" >/dev/null 2>&1 || true
  sleep 4
  if ! systemctl is-active --quiet "$XUI_SERVICE"; then
    warn "$XUI_SERVICE did not come up; rolling back."
    cp -f "$bak" "$XUI_DB"
    systemctl restart "$XUI_SERVICE" >/dev/null 2>&1 || true
    die "Rolled back to backup. Check: journalctl -u $XUI_SERVICE -e --no-pager"
  fi

  # Rotation timer: install in rotate mode, remove otherwise. Persist the setting (sticky).
  if [[ "${ROTATE_MINUTES:-0}" -gt 0 ]]; then
    install_rotate_timer "$ROTATE_MINUTES"
    echo "$ROTATE_MINUTES" > "$PROXY_ROTATE_FILE" 2>/dev/null || true
    log "Rotation ON: active proxy advances every ${ROTATE_MINUTES} min (round-robin, wraps to first)."
  else
    remove_rotate_timer
    rm -f "$PROXY_ROTATE_FILE" 2>/dev/null || true
  fi

  if pgrep -f 'xray-linux-' >/dev/null 2>&1 || pgrep -x xray >/dev/null 2>&1; then
    log "Done. Proxies are LIVE in x-ui. Backup: $bak"
  else
    warn "Panel is up but no Xray process detected — config may be rejected."
    warn "Rollback if needed:  cp '$bak' '$XUI_DB' && systemctl restart $XUI_SERVICE"
  fi
}

# --- rotation (time-based: one active proxy at a time, cycled by a systemd timer) ---

ROTATE_SERVICE_FILE="/etc/systemd/system/proxy-multi-rotate.service"
ROTATE_TIMER_FILE="/etc/systemd/system/proxy-multi-rotate.timer"

install_rotate_timer() {
  local mins="$1"
  local self
  self="$(readlink -f "$0" 2>/dev/null || true)"
  [[ -n "$self" ]] || self="/usr/local/bin/proxy-multi"
  cat > "$ROTATE_SERVICE_FILE" <<EOF
[Unit]
Description=proxy-multi: rotate the active proxy

[Service]
Type=oneshot
ExecStart=${self} rotate
EOF
  cat > "$ROTATE_TIMER_FILE" <<EOF
[Unit]
Description=proxy-multi: rotate the active proxy every ${mins} min

[Timer]
OnActiveSec=${mins}min
OnUnitActiveSec=${mins}min
AccuracySec=10s

[Install]
WantedBy=timers.target
EOF
  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl enable proxy-multi-rotate.timer >/dev/null 2>&1 || true
  systemctl restart proxy-multi-rotate.timer >/dev/null 2>&1 || true
}

remove_rotate_timer() {
  if [[ -f "$ROTATE_TIMER_FILE" || -f "$ROTATE_SERVICE_FILE" ]]; then
    systemctl disable --now proxy-multi-rotate.timer >/dev/null 2>&1 || true
    rm -f "$ROTATE_TIMER_FILE" "$ROTATE_SERVICE_FILE"
    systemctl daemon-reload >/dev/null 2>&1 || true
  fi
}

cmd_rotate() {
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "Run as root."
  ensure_apply_tools
  [[ -f "$XUI_DB" ]] || die "x-ui DB not found at $XUI_DB."
  mkdir -p "$STATE_DIR"

  local tmpl
  tmpl="$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='${XRAY_KEY}';" 2>/dev/null || true)"
  [[ -n "$tmpl" ]] || die "Could not read '${XRAY_KEY}' from $XUI_DB."

  # Current active proxy = the routing rule whose outboundTag is one of ours (px##).
  local cur
  cur="$(printf '%s' "$tmpl" | jq -r --arg pfx "$TAG_PREFIX" \
    'first(.routing.rules[]? | select((.outboundTag // "") | test("^"+$pfx+"[0-9]+$")) | .outboundTag) // ""')"
  [[ -n "$cur" ]] || die "No rotation rule found (not in rotate mode). Run: proxy-multi setup --rotate <min>"

  # Next proxy (sorted px tags, wrap around).
  local next
  next="$(printf '%s' "$tmpl" | jq -r --arg pfx "$TAG_PREFIX" --arg cur "$cur" \
    '([.outbounds[].tag | select(test("^"+$pfx+"[0-9]+$"))] | sort) as $l
     | ($l | index($cur)) as $i
     | if ($l|length)==0 then "" elif $i==null then $l[0] else $l[(($i+1) % ($l|length))] end')"
  [[ -n "$next" ]] || die "Could not compute next proxy."

  if [[ "$next" == "$cur" ]]; then
    log "Only one proxy; nothing to rotate."
    return 0
  fi

  local merged
  merged="$(printf '%s' "$tmpl" | jq --arg pfx "$TAG_PREFIX" --arg next "$next" \
    '.routing.rules |= map(if ((.outboundTag // "") | test("^"+$pfx+"[0-9]+$")) then .outboundTag=$next else . end)')"
  printf '%s' "$merged" | jq empty 2>/dev/null || die "Rotation produced invalid JSON; aborting."

  printf '%s' "$merged" > "${STATE_DIR}/merged-template.json"
  { printf "UPDATE settings SET value='"; sed "s/'/''/g" "${STATE_DIR}/merged-template.json"; printf "' WHERE key='%s';" "$XRAY_KEY"; } | sqlite3 "$XUI_DB" \
    || die "DB write failed during rotation."

  systemctl restart "$XUI_SERVICE" >/dev/null 2>&1 || true
  log "Rotated active proxy: ${cur} -> ${next}"
}

usage() {
  cat <<EOF
proxy-multi v${VERSION} - turn a proxy list into an Xray (x-ui) balancer, automatically

Usage:
  proxy-multi setup [options]   Ask for proxies, test them, generate the config, and
                                (if x-ui is on this box) apply it to the panel + restart.
  proxy-multi add [options]     Append MORE proxies to the saved list (keeps existing px
                                tags), re-test, and re-apply. No need to re-enter the old.
  proxy-multi apply [options]   Re-apply the last generated config to x-ui.
  proxy-multi rotate            Advance to the next proxy (used by the rotation timer).

Options:
  --file FILE        Read proxies from FILE (one per line) instead of asking.
  --inbound TAGS     Route only these inbound tags (comma-separated) through the proxies.
                     Default: all enabled inbounds. Use "all" for the same.
  --rotate MIN       Time-rotation: send ALL traffic through ONE proxy and switch to the
                     next every MIN minutes (round-robin, wraps to the first). Installs a
                     systemd timer. Note: each switch restarts x-ui (brief blip).
  --no-rotate        Switch back to random load-balancing across all proxies (default).
  --no-apply         Only generate the config; do not touch x-ui.
  --db PATH          x-ui database path (default: ${XUI_DB}).

Proxy line formats:
  host:port:user:pass | host:port | socks5://user:pass@host:port | http://user:pass@host:port

Output config: ${OUT_JSON}
Auto-apply is safe: it backs up ${XUI_DB} first and rolls back if x-ui fails to restart.
Env knobs: BALANCER_TAG, TAG_PREFIX, BALANCER_STRATEGY (random|leastPing), TEST_TIMEOUT,
           XUI_DB, XUI_SERVICE, XRAY_KEY
EOF
}

main() {
  local cmd="${1:-setup}"
  shift || true

  PROXY_FILE=""
  NO_APPLY=0
  NO_TEST=0
  APPLY_INBOUND=""
  ROTATE_MINUTES=0
  ROTATE_SET=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --file)      PROXY_FILE="${2:?}"; shift 2 ;;
      --no-test)   NO_TEST=1; shift ;;
      --no-apply)  NO_APPLY=1; shift ;;
      --inbound)   APPLY_INBOUND="${2:?}"; shift 2 ;;
      --db)        XUI_DB="${2:?}"; shift 2 ;;
      --rotate)    ROTATE_MINUTES="${2:?}"; ROTATE_SET=1; shift 2 ;;
      --no-rotate) ROTATE_MINUTES=0; ROTATE_SET=1; shift ;;
      -h|--help)   usage; exit 0 ;;
      *) die "Unknown option: $1" ;;
    esac
  done
  [[ "$ROTATE_MINUTES" =~ ^[0-9]+$ ]] || die "--rotate must be a number of minutes."
  # Sticky rotation: if neither --rotate nor --no-rotate was given, inherit the last
  # setting so `add` (and re-`apply`) keep rotating without re-specifying it.
  if [[ "$ROTATE_SET" -eq 0 && -f "$PROXY_ROTATE_FILE" ]]; then
    ROTATE_MINUTES="$(cat "$PROXY_ROTATE_FILE" 2>/dev/null || echo 0)"
    [[ "$ROTATE_MINUTES" =~ ^[0-9]+$ ]] || ROTATE_MINUTES=0
  fi

  case "$cmd" in
    setup)  cmd_setup ;;
    add)    cmd_add ;;
    apply)  cmd_apply ;;
    rotate) cmd_rotate ;;
    -h|--help|help) usage; exit 0 ;;
    *) die "Unknown command: $cmd (use: proxy-multi --help)" ;;
  esac
}

main "$@"

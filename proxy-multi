#!/usr/bin/env bash
# proxy-multi - turn a list of proxies into an Xray (x-ui) load-balancer.
#
# Interactively asks how many proxies you have, reads "host:port:user:pass" lines,
# tests each one (auto-detects http/socks5, finds the real exit IP + geo, drops the
# dead ones), then generates a ready Xray outbounds + balancer config for x-ui/Xray.
#
# Dependencies: curl only.
# License: MIT
set -euo pipefail

VERSION="0.1.0"

STATE_DIR="${STATE_DIR:-/etc/proxy-multi}"
OUT_JSON="${OUT_JSON:-${STATE_DIR}/xray-outbounds.json}"

GEO_URL="${GEO_URL:-https://ipinfo.io/json}"
TRACE_URL="${TRACE_URL:-https://cloudflare.com/cdn-cgi/trace}"
TEST_TIMEOUT="${TEST_TIMEOUT:-15}"

BALANCER_TAG="${BALANCER_TAG:-proxy-balancer}"
TAG_PREFIX="${TAG_PREFIX:-px}"
BALANCER_STRATEGY="${BALANCER_STRATEGY:-random}"   # random | leastPing (leastPing needs observatory)

# x-ui (3x-ui / MHSanaei) integration
XUI_DB="${XUI_DB:-/etc/x-ui/x-ui.db}"
XUI_SERVICE="${XUI_SERVICE:-x-ui}"
XRAY_KEY="${XRAY_KEY:-xrayTemplateConfig}"

log()  { echo "[$(date +'%F %T')] $*"; }
warn() { echo "WARN: $*" >&2; }
die()  { echo "ERROR: $*" >&2; exit 1; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }

ensure_tools() {
  has_cmd curl || die "curl is required (apt-get install -y curl)."
}

# Minimal JSON string escaper (handles backslash and double-quote).
json_escape() {
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# Extract a top-level string field from a (pretty-printed) JSON blob without jq.
get_json_field() {
  local json="$1" field="$2"
  printf '%s' "$json" | grep -oE "\"${field}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | head -1 \
    | sed -E "s/.*:[[:space:]]*\"([^\"]*)\"/\1/"
}

# Parse one proxy line into P_HOST/P_PORT/P_USER/P_PASS/P_SCHEME.
# Accepts:  host:port:user:pass   |   host:port   |   scheme://[user:pass@]host:port
parse_proxy() {
  local line="${1:-}"
  line="${line//[[:space:]]/}"
  P_HOST=""; P_PORT=""; P_USER=""; P_PASS=""; P_SCHEME=""
  [[ -n "$line" ]] || return 1

  if [[ "$line" == *"://"* ]]; then
    P_SCHEME="${line%%://*}"
    line="${line#*://}"
    if [[ "$line" == *"@"* ]]; then
      local creds="${line%@*}" hostport="${line##*@}"
      P_USER="${creds%%:*}"; P_PASS="${creds#*:}"
      P_HOST="${hostport%%:*}"; P_PORT="${hostport##*:}"
    else
      P_HOST="${line%%:*}"; P_PORT="${line##*:}"
    fi
  else
    local -a f=()
    IFS=':' read -r -a f <<<"$line"
    case "${#f[@]}" in
      2) P_HOST="${f[0]}"; P_PORT="${f[1]}" ;;
      4) P_HOST="${f[0]}"; P_PORT="${f[1]}"; P_USER="${f[2]}"; P_PASS="${f[3]}" ;;
      *) return 1 ;;
    esac
  fi

  [[ -n "$P_HOST" && "$P_PORT" =~ ^[0-9]+$ ]] || return 1
  return 0
}

# Test a proxy. On success sets T_PROTO (http|socks), T_IP, T_GEO, T_ORG and returns 0.
# Auto-detects the protocol unless P_SCHEME forces one.
test_proxy() {
  local host="$1" port="$2" user="$3" pass="$4" want="${5:-}"
  local auth="" s url out ip
  [[ -n "$user" ]] && auth="${user}:${pass}@"

  local -a schemes
  case "$want" in
    http)                 schemes=(http) ;;
    socks|socks5|socks5h) schemes=(socks5h) ;;
    *)                    schemes=(http socks5h) ;;
  esac

  T_PROTO=""; T_IP=""; T_GEO=""; T_ORG=""
  for s in "${schemes[@]}"; do
    url="${s}://${auth}${host}:${port}"
    out="$(curl -s --max-time "$TEST_TIMEOUT" --proxy "$url" "$GEO_URL" 2>/dev/null || true)"
    ip="$(get_json_field "$out" ip)"
    if [[ -z "$ip" ]]; then
      # Fallback: cloudflare trace (gives ip only, no geo).
      out="$(curl -s --max-time "$TEST_TIMEOUT" --proxy "$url" "$TRACE_URL" 2>/dev/null || true)"
      ip="$(printf '%s' "$out" | sed -n 's/^ip=//p' | head -1)"
      if [[ -n "$ip" ]]; then
        T_PROTO="$([[ "$s" == "http" ]] && echo http || echo socks)"
        T_IP="$ip"
        T_GEO="$(printf '%s' "$out" | sed -n 's/^loc=//p' | head -1)"
        T_ORG=""
        return 0
      fi
      continue
    fi
    T_PROTO="$([[ "$s" == "http" ]] && echo http || echo socks)"
    T_IP="$ip"
    local city region country
    city="$(get_json_field "$out" city)"
    region="$(get_json_field "$out" region)"
    country="$(get_json_field "$out" country)"
    T_GEO="$(printf '%s' "${city:+$city, }${region:+$region, }${country}" | sed 's/, *$//')"
    T_ORG="$(get_json_field "$out" org)"
    return 0
  done
  return 1
}

# Emit one Xray outbound object (indented) for a working proxy.
gen_outbound() {
  local tag="$1" proto="$2" host="$3" port="$4" user="$5" pass="$6"
  local users=""
  if [[ -n "$user" ]]; then
    users=", \"users\": [{ \"user\": \"$(json_escape "$user")\", \"pass\": \"$(json_escape "$pass")\" }]"
  fi
  printf '    { "tag": "%s", "protocol": "%s", "settings": { "servers": [{ "address": "%s", "port": %s%s }] } }' \
    "$(json_escape "$tag")" "$proto" "$(json_escape "$host")" "$port" "$users"
}

read_proxy_lines() {
  # Populates the global INPUT_LINES array, either from --file or interactively.
  INPUT_LINES=()
  if [[ -n "${PROXY_FILE:-}" ]]; then
    [[ -f "$PROXY_FILE" ]] || die "File not found: $PROXY_FILE"
    mapfile -t INPUT_LINES < "$PROXY_FILE"
    return 0
  fi

  local n
  read -rp "How many proxies do you want to add? " n
  [[ "$n" =~ ^[0-9]+$ ]] && [[ "$n" -ge 1 ]] || die "Enter a number >= 1."
  echo "Paste each proxy on its own line (host:port:user:pass)."
  local i line
  for i in $(seq 1 "$n"); do
    read -rp "  proxy $i: " line
    INPUT_LINES+=("$line")
  done
}

cmd_setup() {
  ensure_tools
  mkdir -p "$STATE_DIR"

  local -a INPUT_LINES=()
  read_proxy_lines

  local -a outbounds=() tags=()
  local idx=0 line tag
  printf '\n%-24s %-6s %-16s %-26s %s\n' "PROXY" "PROTO" "EXIT_IP" "GEO" "STATUS"
  printf '%s\n' "--------------------------------------------------------------------------------"
  for line in "${INPUT_LINES[@]}"; do
    [[ -n "${line//[[:space:]]/}" ]] || continue
    if ! parse_proxy "$line"; then
      printf '%-24s %-6s %-16s %-26s %s\n' "$line" "-" "-" "-" "BAD-FORMAT"
      continue
    fi
    idx=$((idx + 1))
    tag="${TAG_PREFIX}$(printf '%02d' "$idx")"
    if test_proxy "$P_HOST" "$P_PORT" "$P_USER" "$P_PASS" "$P_SCHEME"; then
      printf '%-24s %-6s %-16s %-26s %s\n' "${P_HOST}:${P_PORT}" "$T_PROTO" "$T_IP" "${T_GEO:-?}" "OK ($tag)"
      outbounds+=("$(gen_outbound "$tag" "$T_PROTO" "$P_HOST" "$P_PORT" "$P_USER" "$P_PASS")")
      tags+=("$tag")
    else
      printf '%-24s %-6s %-16s %-26s %s\n' "${P_HOST}:${P_PORT}" "-" "-" "-" "DEAD/skip"
    fi
  done
  echo

  [[ "${#tags[@]}" -ge 1 ]] || die "No working proxy found; nothing to generate."

  # Warn on duplicate exit IPs (no diversity benefit).
  # (Best-effort: we only have IPs printed above; keeping it simple here.)

  # Join outbound objects.
  local obs_joined="" o first=1
  for o in "${outbounds[@]}"; do
    if [[ "$first" -eq 1 ]]; then obs_joined="$o"; first=0; else obs_joined="${obs_joined},"$'\n'"$o"; fi
  done

  # Build the selector tags array: "px01", "px02", ...
  local tags_joined="" t
  for t in "${tags[@]}"; do tags_joined="${tags_joined:+$tags_joined, }\"$(json_escape "$t")\""; done

  cat > "$OUT_JSON" <<EOF
{
  "outbounds": [
${obs_joined}
  ],
  "routing": {
    "balancers": [
      { "tag": "${BALANCER_TAG}", "selector": [${tags_joined}], "strategy": { "type": "${BALANCER_STRATEGY}" } }
    ],
    "rules": [
      { "type": "field", "inboundTag": ["YOUR_INBOUND_TAG"], "balancerTag": "${BALANCER_TAG}" }
    ]
  }
}
EOF

  log "Generated config for ${#tags[@]} working proxy(ies): $OUT_JSON"
  echo "-------------------- Xray config --------------------"
  cat "$OUT_JSON"
  echo "-----------------------------------------------------"
  echo

  # Full automation: if x-ui is on this box, apply straight into the panel.
  if [[ "${NO_APPLY:-0}" -ne 1 ]] && [[ -f "$XUI_DB" ]]; then
    log "x-ui detected ($XUI_DB) -> applying automatically..."
    cmd_apply
  else
    echo "x-ui not detected (or --no-apply). Apply manually:"
    echo "  Panel -> Xray Configs -> merge the 'outbounds' and 'routing' above,"
    echo "  replace YOUR_INBOUND_TAG with your inbound tag, Save, Restart."
  fi
}

# --- x-ui (3x-ui) auto-apply -------------------------------------------------

ensure_apply_tools() {
  has_cmd sqlite3 || { log "Installing sqlite3..."; apt-get install -y -q sqlite3 >/dev/null 2>&1 || true; }
  has_cmd jq      || { log "Installing jq...";      apt-get install -y -q jq      >/dev/null 2>&1 || true; }
  has_cmd sqlite3 || die "sqlite3 is required (apt-get install -y sqlite3)."
  has_cmd jq      || die "jq is required (apt-get install -y jq)."
}

# JSON array of enabled inbound tags from the x-ui DB.
xui_inbound_tags() {
  sqlite3 "$XUI_DB" "SELECT tag FROM inbounds WHERE enable=1 AND tag IS NOT NULL AND tag<>'';" 2>/dev/null \
    | jq -R . | jq -s 'map(select(length>0))'
}

cmd_apply() {
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "Run as root to modify x-ui."
  ensure_apply_tools
  [[ -f "$OUT_JSON" ]] || die "No generated config ($OUT_JSON). Run: proxy-multi setup"
  [[ -f "$XUI_DB" ]]   || die "x-ui DB not found at $XUI_DB (set XUI_DB=/path/to/x-ui.db)."

  # Current Xray template from the panel DB.
  local tmpl
  tmpl="$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='${XRAY_KEY}';" 2>/dev/null || true)"
  [[ -n "$tmpl" ]] || die "Could not read '${XRAY_KEY}' from $XUI_DB."
  printf '%s' "$tmpl" | jq empty 2>/dev/null || die "Existing template is not valid JSON; aborting (DB untouched)."

  # Which inbound tags route through the proxies.
  local intags
  if [[ -n "${APPLY_INBOUND:-}" && "$APPLY_INBOUND" != "all" ]]; then
    intags="$(printf '%s' "$APPLY_INBOUND" | tr ',' '\n' | jq -R . | jq -s 'map(select(length>0))')"
  else
    intags="$(xui_inbound_tags)"
  fi
  [[ "$(printf '%s' "$intags" | jq 'length')" -ge 1 ]] \
    || die "No enabled inbounds found to route. Create an inbound first, or pass --inbound <tag>."

  # Backup the DB before touching it.
  local stamp bak
  stamp="$(date +%Y%m%d-%H%M%S)"
  bak="${XUI_DB}.proxymulti.${stamp}.bak"
  cp -f "$XUI_DB" "$bak" || die "DB backup failed; aborting."
  log "DB backed up: $bak"

  # Merge proxy outbounds + balancer + routing rule into the template (idempotent).
  local merged
  merged="$(printf '%s' "$tmpl" | jq \
    --slurpfile px "$OUT_JSON" \
    --argjson intags "$intags" \
    --arg baltag "$BALANCER_TAG" '
    ($px[0].outbounds) as $pxob
    | ($pxob | map(.tag)) as $pxtags
    | ($px[0].routing.balancers) as $pxbal
    | {type:"field", inboundTag:$intags, balancerTag:$baltag} as $rule
    | .outbounds = ((.outbounds // []) | map(select(.tag as $t | ($pxtags | index($t)) | not))) + $pxob
    | .routing = (.routing // {})
    | .routing.balancers = ((.routing.balancers // []) | map(select(.tag != $baltag))) + $pxbal
    | .routing.rules = ((.routing.rules // []) | map(select((.balancerTag // "") != $baltag))) + [$rule]
  ' 2>/dev/null)" || { warn "merge failed"; die "jq merge failed; DB untouched (backup: $bak)."; }
  printf '%s' "$merged" | jq empty 2>/dev/null || die "Merged config invalid; DB untouched (backup: $bak)."

  # Write the merged template back (stream via stdin; escape single quotes for SQL).
  printf '%s' "$merged" > "${STATE_DIR}/merged-template.json"
  if ! { printf "UPDATE settings SET value='"; sed "s/'/''/g" "${STATE_DIR}/merged-template.json"; printf "' WHERE key='%s';" "$XRAY_KEY"; } | sqlite3 "$XUI_DB"; then
    cp -f "$bak" "$XUI_DB"
    die "DB write failed; restored backup ($bak)."
  fi
  local nprox routed
  nprox="$(jq '.outbounds | length' "$OUT_JSON" 2>/dev/null || echo '?')"
  routed="$(printf '%s' "$intags" | jq -cr 'join(", ")' 2>/dev/null || echo '?')"
  log "x-ui Xray template updated (${nprox} proxies; routing [${routed}] -> ${BALANCER_TAG})."

  # Restart and verify; auto-rollback if the panel fails to come up.
  systemctl restart "$XUI_SERVICE" >/dev/null 2>&1 || true
  sleep 4
  if ! systemctl is-active --quiet "$XUI_SERVICE"; then
    warn "$XUI_SERVICE did not come up; rolling back."
    cp -f "$bak" "$XUI_DB"
    systemctl restart "$XUI_SERVICE" >/dev/null 2>&1 || true
    die "Rolled back to backup. Check: journalctl -u $XUI_SERVICE -e --no-pager"
  fi

  if pgrep -f 'xray-linux-' >/dev/null 2>&1 || pgrep -x xray >/dev/null 2>&1; then
    log "Done. Proxy balancer is LIVE in x-ui. Backup: $bak"
  else
    warn "Panel is up but no Xray process detected — config may be rejected."
    warn "Rollback if needed:  cp '$bak' '$XUI_DB' && systemctl restart $XUI_SERVICE"
  fi
}

usage() {
  cat <<EOF
proxy-multi v${VERSION} - turn a proxy list into an Xray (x-ui) balancer, automatically

Usage:
  proxy-multi setup [options]   Ask for proxies, test them, generate the config, and
                                (if x-ui is on this box) apply it to the panel + restart.
  proxy-multi apply [options]   Re-apply the last generated config to x-ui.

Options:
  --file FILE        Read proxies from FILE (one per line) instead of asking.
  --inbound TAGS     Route only these inbound tags (comma-separated) through the proxies.
                     Default: all enabled inbounds. Use "all" for the same.
  --no-apply         Only generate the config; do not touch x-ui.
  --db PATH          x-ui database path (default: ${XUI_DB}).

Proxy line formats:
  host:port:user:pass | host:port | socks5://user:pass@host:port | http://user:pass@host:port

Output config: ${OUT_JSON}
Auto-apply is safe: it backs up ${XUI_DB} first and rolls back if x-ui fails to restart.
Env knobs: BALANCER_TAG, TAG_PREFIX, BALANCER_STRATEGY (random|leastPing), TEST_TIMEOUT,
           XUI_DB, XUI_SERVICE, XRAY_KEY
EOF
}

main() {
  local cmd="${1:-setup}"
  shift || true

  PROXY_FILE=""
  NO_APPLY=0
  APPLY_INBOUND=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --file)     PROXY_FILE="${2:?}"; shift 2 ;;
      --no-apply) NO_APPLY=1; shift ;;
      --inbound)  APPLY_INBOUND="${2:?}"; shift 2 ;;
      --db)       XUI_DB="${2:?}"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  case "$cmd" in
    setup) cmd_setup ;;
    apply) cmd_apply ;;
    -h|--help|help) usage; exit 0 ;;
    *) die "Unknown command: $cmd (use: proxy-multi --help)" ;;
  esac
}

main "$@"
